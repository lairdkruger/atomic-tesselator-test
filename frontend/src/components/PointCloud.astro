---
---

<div class="point-cloud-container">
  <canvas id="point-cloud-canvas"></canvas>
  <div class="overlay" id="point-cloud-overlay">
    <span class="overlay-text">Loading...</span>
  </div>
</div>

<style>
  .point-cloud-container {
    width: 100%;
    height: 100%;
    position: relative;
  }

  canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    transition: opacity 0.3s;
  }

  .overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .overlay-text {
    color: #666;
    font-size: 14px;
    animation: pulse 2s ease-in-out infinite;
  }

  .overlay.error .overlay-text {
    color: #c44;
    animation: none;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>

<script>
  import { Renderer, Camera, OrbitControls, Scene, Time, Vec3 } from "renderer";
  import type { ColorMapEntry } from "renderer";
  import { $appState, $eposData, $highlightedMq, $colorMap, $ionCutoff, DEFAULT_COLOR_MAP } from "../stores/ui";
  import { EposData } from "parser";

  const overlay = document.getElementById("point-cloud-overlay")!;
  const overlayText = overlay.querySelector(".overlay-text")!;

  let initialized = false;

  $appState.subscribe((state) => {
    if (state.status === "loading") {
      overlayText.textContent = state.message || "Loading...";
      overlay.classList.remove("hidden", "error");
    } else if (state.status === "error") {
      overlayText.textContent = state.message;
      overlay.classList.add("error");
      overlay.classList.remove("hidden");
    } else if (state.status === "ready" && !initialized) {
      const data = $eposData.get();
      if (data) {
        initialized = true;
        overlay.classList.add("hidden");
        initRenderer(data);
      }
    }
  });

  async function initRenderer(eposData: EposData) {
    const canvas = document.getElementById("point-cloud-canvas") as HTMLCanvasElement;
    if (!canvas) throw new Error("canvas not found");

    const renderer = await Renderer.create(canvas, {
      devicePixelRatio: window.devicePixelRatio,
    });

    const device = renderer.getDevice();
    const camera = new Camera(device, "main", {
      fov: Math.PI / 4,
      near: 0.1,
      far: 500,
    });
    renderer.registerCamera(camera);

    const scene = new Scene("main");
    scene.add(camera);

    const controls = new OrbitControls(canvas, camera, {
      radius: 100,
      elevation: 0.3,
    });

    renderer.setPointCloudBuffer(eposData.buffer, eposData.count);

    // center orbit on data midpoint
    const xCol = eposData.column("x");
    const yCol = eposData.column("y");
    const zCol = eposData.column("z");
    let xMin = Infinity, xMax = -Infinity;
    let yMin = Infinity, yMax = -Infinity;
    let zMin = Infinity, zMax = -Infinity;

    for (let i = 0; i < eposData.count; i += 1000) {
      const x = xCol.get(i), y = yCol.get(i), z = zCol.get(i);
      if (x < xMin) xMin = x; if (x > xMax) xMax = x;
      if (y < yMin) yMin = y; if (y > yMax) yMax = y;
      if (z < zMin) zMin = z; if (z > zMax) zMax = z;
    }

    controls.setTarget(
      (xMin + xMax) / 2,
      (yMin + yMax) / 2,
      (zMin + zMax) / 2,
    );

    renderer.setGridBounds(new Vec3(xMin, yMin, zMin), new Vec3(xMax, yMax, zMax));

    // react to highlight changes
    $highlightedMq.subscribe((highlight) => {
      const baseMap = $colorMap.get();
      if (!highlight) {
        renderer.updatePointCloudPalette(baseMap);
        return;
      }

      const dimmed: ColorMapEntry[] = baseMap.map((entry) => {
        const entryMid = (entry.mqMin + entry.mqMax) / 2;
        if (entryMid >= highlight.min && entryMid <= highlight.max) {
          return { ...entry, visibility: 10.0 };
        }
        return { ...entry, r: 0.1, g: 0.1, b: 0.1, visibility: 0.0 };
      });
      renderer.updatePointCloudPalette(dimmed);
    });

    $ionCutoff.subscribe((cutoff) => {
      renderer.setIonCutoff(cutoff);
    });

    const onResize = () => {
      renderer.resize(canvas.clientWidth, canvas.clientHeight);
    };
    window.addEventListener("resize", onResize);

    const time = new Time();
    const TARGET_FPS = 60;
    const FRAME_INTERVAL = 1000 / TARGET_FPS;
    let lastFrameTime = 0;

    function frame(now: number) {
      requestAnimationFrame(frame);
      if (now - lastFrameTime < FRAME_INTERVAL) return;
      lastFrameTime = now - ((now - lastFrameTime) % FRAME_INTERVAL);

      time.update();
      controls.update(time.delta);
      scene.root.updateWorldMatrix();
      renderer.render(camera);
    }
    requestAnimationFrame(frame);
  }
</script>
